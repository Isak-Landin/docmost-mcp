# ============================================================
# Docmost MCP — environment configuration
# Copy this file to .env and fill in the real values.
# All runtime values are read from env. No hardcoding in code.
# ============================================================

# ------------------------------------------------------------
# Docmost PostgreSQL database
# The API connects directly to the live Docmost database.
#
# Option A — full DSN (takes priority if set):
DOCMOST_DB_URL=postgresql://docmost:STRONG_DB_PASSWORD@db:5432/docmost

# Option B — individual components (used when DOCMOST_DB_URL is not set):
DOCMOST_DB_HOST=db
DOCMOST_DB_PORT=5432
DOCMOST_DB_NAME=docmost
DOCMOST_DB_USER=docmost
DOCMOST_DB_PASSWORD=STRONG_DB_PASSWORD

# ------------------------------------------------------------
# Docmost application — used for REST API write operations
# ------------------------------------------------------------
# Base URL of the running Docmost web application.
DOCMOST_APP_URL=http://localhost:3000

# Credentials for a Docmost user account.
# The token obtained at login is kept in memory only — never written to disk or DB.
DOCMOST_USER_EMAIL=your-email@example.com
DOCMOST_USER_PASSWORD=your-password

# ------------------------------------------------------------
# REST + MCP server bind + external exposure
# ------------------------------------------------------------
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8099
EXTERNAL_PORT=8099

# Comma-separated list of Host header values the MCP transport will accept.
# Required when the service runs behind a reverse proxy with a custom domain.
# Example: MCP_ALLOWED_HOSTS=mcp-docmost.isaklandin.com
# Leave empty to disable DNS-rebinding protection (not recommended for production).
MCP_ALLOWED_HOSTS=mcp-docmost.isaklandin.com

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# dev | prod
MODE=dev
# ALL | DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
