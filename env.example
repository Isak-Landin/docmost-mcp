# ============================================================
# Docmost Database API — environment configuration
# Copy this file to .env and fill in the real values.
# All runtime values are read from env. No hardcoding in code.
# ============================================================

# ------------------------------------------------------------
# Docmost PostgreSQL database
# The API connects directly to the live Docmost database.
#
# Option A — full DSN (takes priority if set):
DOCMOST_DB_URL=postgresql://docmost:STRONG_DB_PASSWORD@db:5432/docmost

# Option B — individual components (used when DOCMOST_DB_URL is not set):
DOCMOST_DB_HOST=db
DOCMOST_DB_PORT=5432
DOCMOST_DB_NAME=docmost
DOCMOST_DB_USER=docmost
DOCMOST_DB_PASSWORD=STRONG_DB_PASSWORD

# ------------------------------------------------------------
# API server bind + external exposure
# ------------------------------------------------------------
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8099
EXTERNAL_PORT=8099

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# dev | prod
MODE=dev
# ALL | DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
